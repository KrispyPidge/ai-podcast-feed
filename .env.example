# xAI — API key from https://console.x.ai/
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_VOICE=eve

# GitHub — personal access token with repo scope (only needed for auto-push from local runs)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=KrispyPidge/ai-podcast-feed

# Podcast metadata
PODCAST_TITLE=Chris's Morning Briefing
PODCAST_DESCRIPTION=A daily AI-generated audio digest — news, updates, and quick hits.
PODCAST_AUTHOR=Chris
PODCAST_LINK=https://krispypidge.github.io/ai-podcast-feed
PODCAST_IMAGE_URL=https://krispypidge.github.io/ai-podcast-feed/assets/cover.jpg
